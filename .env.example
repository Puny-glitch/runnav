# ============================================================
# RunNav — Required Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to source control.
#
# EXPO_PUBLIC_ prefix = safe to bundle into the client app.
# Variables WITHOUT that prefix are server-only secrets.
# ============================================================

# ------ Supabase (client-safe) ------
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ------ Maps ------
EXPO_PUBLIC_STADIA_MAPS_KEY=your_stadia_maps_api_key

# ------ Analytics ------
EXPO_PUBLIC_POSTHOG_KEY=your_posthog_key

# ------ Crash reporting ------
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn

# ------ Payments (client SDK key) ------
REVENUECAT_API_KEY_ANDROID=your_revenuecat_android_key
REVENUECAT_API_KEY_IOS=your_revenuecat_ios_key

# ------ Server-only secrets (Edge Functions only — NEVER use EXPO_PUBLIC_ prefix) ------
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_server_only
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_shared_secret
