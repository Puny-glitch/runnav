# ============================================================
# RunNav .gitignore
# Covers: Node, Expo, Python, macOS, editors, env files
# ============================================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Expo ---
.expo/
dist/
web-build/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# --- Build output ---
build/
out/

# --- Environment / secrets (CRITICAL — never commit these) ---
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Testing / coverage ---
coverage/
.nyc_output/

# --- Turbo ---
.turbo/

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

# --- Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Python (if any tooling scripts) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
venv/
env/
.venv/

# --- TypeScript ---
*.tsbuildinfo

# --- Supabase local dev ---
supabase/.branches/
supabase/.temp/
.env.local
.env
